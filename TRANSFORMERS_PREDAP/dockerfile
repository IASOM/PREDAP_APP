# NVIDIA TensorFlow image with CUDA/cuDNN/TensorRT and TensorFlow preinstalled.
FROM nvcr.io/nvidia/tensorflow:25.02-tf2-py3

WORKDIR /app

ARG MODELS_FOLDER_NAME=quantized_models
ARG READ_DATA_FOLDER_NAME=data
ARG SAVE_DATA_FOLDER_NAME=production_predictions

ENV MODELS_FOLDER_NAME=${MODELS_FOLDER_NAME}
ENV READ_DATA_FOLDER_NAME=${READ_DATA_FOLDER_NAME}
ENV SAVE_DATA_FOLDER_NAME=${SAVE_DATA_FOLDER_NAME}

RUN mkdir -p \
    /app/${MODELS_FOLDER_NAME} \
    /app/${READ_DATA_FOLDER_NAME} \
    /app/${SAVE_DATA_FOLDER_NAME}

# Do not install tensorflow here: the NVIDIA base image already provides it.
COPY requirements-docker.txt .
RUN python -m pip install --no-cache-dir -r requirements-docker.txt

COPY . .

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
